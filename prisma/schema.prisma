// Viva La Mañana — esquema Prisma.
// Fase 2: núcleo (User, ClientProfile, SiteSetting, taxonomías).
// Los módulos (News, Event, Package, etc.) se agregan en sus fases. Ver docs/03.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: la URL de conexión vive en prisma.config.ts (migraciones) y en el
// driver adapter en runtime (lib/db.ts). El schema solo declara el provider.
datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  CLIENTE
  VISITANTE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  role      Role     @default(CLIENTE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile ClientProfile?
  news          News[]

  @@index([role])
}

model ClientProfile {
  id      String  @id @default(cuid())
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company String?
  phone   String?
  taxId   String?
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Configuración global y flags de secciones (key/value JSON). Ver docs/02 §8.
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Category {
  id   String @id @default(cuid())
  name String
  slug String @unique
  news News[] @relation("NewsCategories")
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique
  news News[] @relation("NewsTags")
}

model News {
  id         String        @id @default(cuid())
  title      String
  slug       String        @unique
  excerpt    String
  content    String
  coverUrl   String?
  videoUrl   String?
  podcastUrl String?
  status     ContentStatus @default(DRAFT)
  featured   Boolean       @default(false)
  breaking   Boolean       @default(false)
  views      Int           @default(0)
  publishedAt DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  categories Category[] @relation("NewsCategories")
  tags       Tag[]      @relation("NewsTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([featured])
}
