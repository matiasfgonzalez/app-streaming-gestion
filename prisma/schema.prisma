// Viva La Mañana — esquema Prisma.
// Fase 2: núcleo (User, ClientProfile, SiteSetting, taxonomías).
// Los módulos (News, Event, Package, etc.) se agregan en sus fases. Ver docs/03.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: la URL de conexión vive en prisma.config.ts (migraciones) y en el
// driver adapter en runtime (lib/db.ts). El schema solo declara el provider.
datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  CLIENTE
  VISITANTE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum EventStatus {
  UPCOMING
  LIVE
  FINISHED
}

enum QuoteStatus {
  NEW
  IN_REVIEW
  QUOTED
  CLOSED
}

enum QuoteService {
  INTERNET
  STREAMING
  FOTOS
  VIDEOS
  CONDUCTOR
  PUBLICIDAD
  REDES
  COMMUNITY_MANAGER
  ENTREVISTAS
  COBERTURA
}

enum ContractStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  EXPIRED
}

enum BillingCycle {
  DAILY
  WEEKLY
  MONTHLY
}

enum PaymentMethod {
  TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CreativeType {
  LOGO
  IMAGE
}

enum SponsorStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum Weekday {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum BannerPlacement {
  HOME
  NEWS
  EVENTS
  SIDEBAR
  FOOTER
  HEADER
  POPUP
  INLINE
  LANDING
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  role      Role     @default(CLIENTE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile ClientProfile?
  news          News[]
  contracts     AdContract[]

  @@index([role])
}

model ClientProfile {
  id      String  @id @default(cuid())
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company String?
  phone   String?
  taxId   String?
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Configuración global y flags de secciones (key/value JSON). Ver docs/02 §8.
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Category {
  id   String @id @default(cuid())
  name String
  slug String @unique
  news News[] @relation("NewsCategories")
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique
  news News[] @relation("NewsTags")
}

model News {
  id         String        @id @default(cuid())
  title      String
  slug       String        @unique
  excerpt    String
  content    String
  coverUrl   String?
  videoUrl   String?
  podcastUrl String?
  status     ContentStatus @default(DRAFT)
  featured   Boolean       @default(false)
  breaking   Boolean       @default(false)
  views      Int           @default(0)
  publishedAt DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  categories Category[] @relation("NewsCategories")
  tags       Tag[]      @relation("NewsTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([featured])
}

model Event {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  venue       String?
  address     String?
  lat         Float?
  lng         Float?
  startsAt    DateTime
  endsAt      DateTime?
  status      EventStatus @default(UPCOMING)
  coverUrl    String?
  artists     String[]    @default([])
  hosts       String[]    @default([])
  views       Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes QuoteRequest[]

  @@index([status, startsAt])
}

model QuoteRequest {
  id       String         @id @default(cuid())
  name     String
  contact  String
  services QuoteService[] @default([])
  venue    String?
  dates    String?
  schedule String?
  details  String?
  status   QuoteStatus    @default(NEW)

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([status, createdAt])
}

model Package {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  description  String
  priceMonthly Int
  priceWeekly  Int?
  priceDaily   Int?
  features     String[] @default([])
  active       Boolean @default(true)
  order        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts AdContract[]

  @@index([active, order])
}

model AdContract {
  id           String         @id @default(cuid())
  clientId     String? // null si lo crea el ADMIN "de palabra"
  client       User?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  packageId    String
  package      Package        @relation(fields: [packageId], references: [id])
  status       ContractStatus @default(PENDING)
  billingCycle BillingCycle   @default(MONTHLY)
  title        String
  description  String?
  socials      String? // links de redes (texto libre)
  startDate    DateTime?
  endDate      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatives Creative[]
  payments  Payment[]

  @@index([status, createdAt])
  @@index([clientId])
}

model Creative {
  id         String       @id @default(cuid())
  contractId String
  contract   AdContract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type       CreativeType @default(IMAGE)
  url        String
  alt        String?
  order      Int          @default(0)
}

model Payment {
  id           String        @id @default(cuid())
  contractId   String
  contract     AdContract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  amount       Int
  method       PaymentMethod @default(TRANSFER)
  status       PaymentStatus @default(PENDING)
  proofUrl     String?
  paidAt       DateTime?
  reviewedById String? // User.id del admin que resolvió
  reviewedAt   DateTime?
  notes        String?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
}

model Sponsor {
  id          String        @id @default(cuid())
  name        String
  logoUrl     String?
  description String?
  website     String?
  socials     String?
  status      SponsorStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  clicks      Int           @default(0)
  impressions Int           @default(0)
  order       Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, order])
}

model Banner {
  id          String          @id @default(cuid())
  title       String?
  imageUrl    String
  link        String?
  placement   BannerPlacement @default(HOME)
  active      Boolean         @default(true)
  startDate   DateTime?
  endDate     DateTime?
  clicks      Int             @default(0)
  impressions Int             @default(0)
  order       Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placement, active, order])
}

/// Programa de radio: conductores, invitados, y sus horarios semanales.
model RadioProgram {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  hosts       String[] @default([]) // conductores
  guests      String[] @default([]) // invitados
  coverUrl    String?
  active      Boolean  @default(true)
  order       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules RadioSchedule[]
  podcasts  Podcast[]

  @@index([active, order])
}

/// Franja horaria de un programa. `isRerun` marca repeticiones.
model RadioSchedule {
  id        String       @id @default(cuid())
  programId String
  program   RadioProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  day       Weekday
  startTime String // "08:00"
  endTime   String // "11:00"
  isRerun   Boolean      @default(false)

  @@index([programId])
  @@index([day, startTime])
}

/// Programa anterior / podcast: audio propio (audioUrl) o YouTube (youtubeId).
model Podcast {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?
  audioUrl    String?
  youtubeId   String?
  coverUrl    String?
  programId   String?
  program     RadioProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  publishedAt DateTime      @default(now())

  createdAt DateTime @default(now())

  @@index([publishedAt])
}
